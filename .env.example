PORT=3000

# ── OpenAI ────────────────────────────────────────────────────────────────────
# Required for answer generation and embeddings.
# Without it the system falls back to keyword search and a bullet-point response.
# Get your key at: https://platform.openai.com/api-keys
OPENAI_API_KEY=

# Model used for chat completions (default: gpt-4o-mini)
OPENAI_MODEL=gpt-4o-mini

# Model used for embeddings (default: text-embedding-3-small, produces 1536-dim vectors)
OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# ── PostgreSQL ────────────────────────────────────────────────────────────────
# Default matches the docker-compose.yml service. Change for staging/production.
DATABASE_URL=postgres://raguser:ragpass@localhost:5432/ragdb

# ── Supabase ──────────────────────────────────────────────────────────────────
# All three values are in the Supabase dashboard → Project Settings → API.
#
# SUPABASE_URL   — your project URL (e.g. https://xxxx.supabase.co)
#                  Dashboard: Project Settings → API → Project URL
SUPABASE_URL=https://your-project-ref.supabase.co

# SUPABASE_ANON_KEY — safe to use in the browser; used by the admin dashboard
#                     to initialise the Supabase JS SDK for login.
#                     Dashboard: Project Settings → API → Project API keys → anon / public
SUPABASE_ANON_KEY=sb_publishable_...

# ── Seeding ───────────────────────────────────────────────────────────────────
# UUID of the tenant that owns the seed product catalog and articles.
# Create a tenant first via POST /tenants, then paste its ID here.
SEED_TENANT_ID=
