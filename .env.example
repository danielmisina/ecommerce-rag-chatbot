PORT=3000

# OpenAI — answer generation (optional; fallback used if missing)
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# OpenAI — embeddings (optional; keyword fallback used if missing)
OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# PostgreSQL connection string
DATABASE_URL=postgres://raguser:ragpass@localhost:5432/ragdb

# Multi-tenancy
# All three values are found in Supabase dashboard → Project Settings → API
SUPABASE_JWT_SECRET=your-supabase-jwt-secret
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-supabase-anon-key

